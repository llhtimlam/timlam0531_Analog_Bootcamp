** sch_path: /mnt/c/Users/User/Documents/GitHub/timlam0531_Analog_Bootcamp/analog/schematics/tb_cmrr.sch
**.subckt tb_cmrr vout
*.opin vout
VDD VDD GND 1.8
VSS VSS GND 0
VCM net2 GND dc 0.9 ac 1
VDIFF net2 net4 0
R1 net3 net2 5000k m=1
R2 net1 net4 5000k m=1
x1 VDD vout net3 net1 VSS opamp_two_stage
**** begin user architecture code


.option scale=1u
.ac dec 10 1 100meg
.control
  run
  * Common-Mode Gain (Acm) profile
  let acm_db = db(v(vout))

  * CMRR = Adm_dB - Acm_dB
  let cmrr = 58.4 - acm_db

  plot cmrr
.endc



.param mc_mm_switch=0
.param mc_pr_switch=0
.include /home/user/.volare/sky130A/libs.tech/ngspice/corners/tt.spice
